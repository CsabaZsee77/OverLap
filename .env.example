# .env.example — MotoMeter szerver konfiguráció
# Másold .env-re és töltsd ki a valódi értékekkel.
# A docker-compose.yml ebből olvassa be a változókat.

# ── Backend ───────────────────────────────────────────────────────────────────
# SQLite adatbázis helye a konténerben (volume-mountolt)
MOTOMETER_DB=/data/motometer.db

# CORS — frontend domain (prod-ban pontosítsd!)
# Fejlesztéshez: CORS_ORIGINS=*
CORS_ORIGINS=https://motometer.yourdomain.com

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=motometer.yourdomain.com

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# E-mail cím a certbot értesítésekhez
CERTBOT_EMAIL=your@email.com
